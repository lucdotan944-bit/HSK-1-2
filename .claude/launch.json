{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "hsk-api",
      "runtimeExecutable": "python3",
      "runtimeArgs": ["-m", "uvicorn", "main:app", "--port", "8000"],
      "port": 8000,
      "autoPort": false
    },
    {
      "name": "hsk-web",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev"],
      "cwd": "web",
      "port": 3000,
      "autoPort": false
    }
  ]
}
